ight3_sub = \"Ein Produkt. Alle Ihre Zonen.\" %}\n  {% assign ingredients = \"Kojisäure · Kurkuma · Niacinamid · Retinol · Vitamine C, E, B\" %}\n\n{% else %}\n  {% assign main_title = \"Finally. Skin you're proud of.\" %}\n  {% assign left1_title = \"Wear your favourite outfits again.\" %}\n  {% assign left1_sub = \"Backless tops, shorts. Without a second thought.\" %}\n  {% assign left2_title = \"Where creams gave up.\" %}\n  {% assign left2_sub = \"5 clinically proven actives in 1 spray.\" %}\n  {% assign left3_title = \"30 seconds. Every evening.\" %}\n  {% assign left3_sub = \"1 spray, massage, rinse. No more long routines.\" %}\n  {% assign right1_title = \"Visible in 2 to 4 weeks.\" %}\n  {% assign right1_sub = \"Not in 6 months. In your mirror.\" %}\n  {% assign right2_title = \"Go out without hiding.\" %}\n  {% assign right2_sub = \"No foundation needed. For the first time in a long time.\" %}\n  {% assign right3_title = \"Face. Underarms. Thighs. Bikini.\" %}\n  {% assign right3_sub = \"One product. All your zones.\" %}\n  {% assign ingredients = \"Kojic Acid · Turmeric · Niacinamide · Retinol · Vitamins C, E, B\" %}\n{% endif %}\n\n<style>\n  .kojic-wrap {\n    background: #F5EDE0;\n    border-radius: 16px;\n    padding: 24px 16px 0;\n    font-family: inherit;\n  }\n  .kojic-title {\n    text-align: center;\n    font-size: 22px;\n    font-weight: 800;\n    color: #2b1d0e;\n    line-height: 1.25;\n    margin-bottom: 10px;\n  }\n  .kojic-divider {\n    border: none;\n    border-top: 1px solid #c8a96e;\n    margin: 0 0 20px;\n  }\n  .kojic-body {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    gap: 0 12px;\n    align-items: center;\n    margin-bottom: 0;\n  }\n  .kojic-col {\n    display: flex;\n    flex-direction: column;\n    gap: 24px;\n  }\n  .kojic-block {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n  .kojic-block-header {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .kojic-block svg {\n    flex-shrink: 0;\n    width: 28px;\n    height: 28px;\n  }\n  .kojic-col-right .kojic-block-header {\n    flex-direction: row-reverse;\n    text-align: right;\n  }\n  .kojic-block-title {\n    font-size: 13px;\n    font-weight: 700;\n    color: #2b1d0e;\n    line-height: 1.3;\n  }\n  .kojic-col-right .kojic-block-title {\n    text-align: right;\n  }\n  .kojic-block-sub {\n    font-size: 11px;\n    color: #5a4a3a;\n    font-style: italic;\n    line-height: 1.4;\n  }\n  .kojic-col-right .kojic-block-sub {\n    text-align: right;\n  }\n  .kojic-bottle {\n    text-align: center;\n    font-size: 11px;\n    color: #c8a96e;\n    font-style: italic;\n    padding: 8px 4px;\n    border: 1.5px solid #c8a96e;\n    border-radius: 12px;\n    writing-mode: vertical-rl;\n    min-height: 180px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    letter-spacing: 1px;\n  }\n  .kojic-ingredients {\n    text-align: center;\n    font-size: 12px;\n    color: #a07830;\n    padding: 14px 0;\n    border-top: 1px solid #c8a96e;\n    margin-top: 20px;\n    letter-spacing: 0.3px;\n  }\n  @media (max-width: 480px) {\n    .kojic-body {\n      grid-template-columns: 1fr;\n    }\n    .kojic-bottle {\n      writing-mode: horizontal-tb;\n      min-height: auto;\n      padding: 10px;\n    }\n    .kojic-col-right .kojic-block-header,\n    .kojic-col-right .kojic-block-title,\n    .kojic-col-right .kojic-block-sub {\n      flex-direction: row;\n      text-align: left;\n    }\n    .kojic-title { font-size: 18px; }\n  }\n</style>\n\n<div class=\"kojic-wrap\">\n\n  <div class=\"kojic-title\">{{ main_title }}</div>\n  <hr class=\"kojic-divider\">\n\n  <div class=\"kojic-body\">\n\n    <!-- Colonne gauche -->\n    <div class=\"kojic-col kojic-col-left\">\n\n      <div class=\"kojic-block\">\n        <div class=\"kojic-block-header\">\n          <svg viewBox=\"0 0 28 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"14\" cy=\"14\" r=\"10\" stroke=\"#c8a96e\" stroke-width=\"1.4\" fill=\"none\"/>\n            <path d=\"M9 9 L14 5 L19 9\" stroke=\"#c8a96e\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n            <line x1=\"14\" y1=\"5\" x2=\"14\" y2=\"18\" stroke=\"#c8a96e\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n            <line x1=\"10\" y1=\"18\" x2=\"18\" y2=\"18\" stroke=\"#c8a96e\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n          </svg>\n          <span class=\"kojic-block-title\">{{ left1_title }}</span>\n        </div>\n        <div class=\"kojic-block-sub\">{{ left1_sub }}</div>\n      </div>\n\n      <div class=\"kojic-block\">\n        <div class=\"kojic-block-header\">\n          <svg viewBox=\"0 0 28 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M14 4 L14 8 M14 20 L14 24 M4 14 L8 14 M20 14 L24 14\" stroke=\"#c8a96e\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n            <path d=\"M7 7 L10 10 M18 18 L21 21 M21 7 L18 10 M10 18 L7 21\" stroke=\"#c8a96e\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n            <circle cx=\"14\" cy=\"14\" r=\"3.5\" fill=\"#c8a96e\" opacity=\"0.5\"/>\n          </svg>\n          <span class=\"kojic-block-title\">{{ left2_title }}</span>\n        </div>\n        <div class=\"kojic-block-sub\">{{ left2_sub }}</div>\n      </div>\n\n      <div class=\"kojic-block\">\n        <div class=\"kojic-block-header\">\n          <svg viewBox=\"0 0 28 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"14\" cy=\"15\" r=\"9\" stroke=\"#c8a96e\" stroke-width=\"1.4\" fill=\"none\"/>\n            <line x1=\"14\" y1=\"15\" x2=\"14\" y2=\"10\" stroke=\"#c8a96e\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n            <line x1=\"14\" y1=\"15\" x2=\"18\" y2=\"17\" stroke=\"#c8a96e\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n            <line x1=\"11\" y1=\"4\" x2=\"17\" y2=\"4\" stroke=\"#c8a96e\" stroke-width=\"1.4\" stroke-linecap=\"